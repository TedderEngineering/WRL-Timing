# ─── Database ──────────────────────────────────────────────────────────────────
# Default matches docker-compose.yml local Postgres
DATABASE_URL=postgresql://racetrace_dev:devpassword123@localhost:5433/racetrace_dev
DIRECT_URL=postgresql://racetrace_dev:devpassword123@localhost:5433/racetrace_dev

# ─── Auth (required) ─────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-to-64-char-random-hex-for-access-tokens
JWT_REFRESH_SECRET=change-me-to-64-char-random-hex-for-refresh-tokens
BCRYPT_ROUNDS=12

# ─── Stripe (use sk_test_ / pk_test_ keys for dev) ──────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...              # optional
STRIPE_PRICE_TEAM_ANNUAL=price_...             # optional

# ─── Stripe (Client / Vite) ─────────────────────────────────────────────────
VITE_STRIPE_PRO_PRICE_ID=price_...
VITE_STRIPE_TEAM_PRICE_ID=price_...

# ─── Supabase (optional for local dev — file storage) ───────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Email (optional — Resend) ──────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@tedderengineering.com

# ─── URLs ────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# ─── Monitoring (optional) ──────────────────────────────────────────────────
SENTRY_DSN=

# ─── General ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
